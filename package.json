{
  "name": "gml-assistant",
  "version": "1.0.0",
  "description": "GML Assistant - GameMaker AI Development Tool",
  "main": "src/main/main.js",
  "scripts": {
    "start": "concurrently \"npm run vite\" \"wait-on http://localhost:5173 && electron .\"",
    "vite": "vite",
    "build": "vite build && electron-builder",
    "dev": "npm run start"
  },
  "keywords": [
    "gamemaker",
    "gml",
    "ai",
    "electron"
  ],
  "author": "GML Assistant",
  "license": "MIT",
  "dependencies": {
    "node-llama-cpp": "^3.18.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.gmlassistant.app",
    "productName": "GML Assistant",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
